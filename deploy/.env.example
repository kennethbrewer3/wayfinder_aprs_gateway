# Packet input: kiss, simulator, replay, aprsis
APRS_PACKET_SOURCE=kiss

# Required when APRS_PACKET_SOURCE=simulator
# APRS_SIMULATOR_CONFIG=/app/simulator.json
# APRS_SIMULATOR_LAYER_NAME=APRS Simulator

# KISS TCP server on the SDR host (Direwolf, etc.)
APRS_KISS_HOST=host.docker.internal
APRS_KISS_PORT=8001

# Wayfinder mapping server that receives parsed positions
APRS_MAPPING_SERVER_URL=https://example.com/api/aprs/position

# Optional bearer token for the mapping server
APRS_AUTH_TOKEN=

APRS_LOG_LEVEL=info
