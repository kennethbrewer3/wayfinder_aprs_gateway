# KISS input from Direwolf (or another KISS TCP server) on the SDR host.
# Copy to your compose directory as .env:
#   cp deploy/env/.env.kiss.example .env
#
# Use with bridge networking and extra_hosts: host.docker.internal:host-gateway

APRS_PACKET_SOURCE=kiss

# KISS TCP server on the SDR host (Direwolf KISSPORT)
APRS_KISS_HOST=host.docker.internal
APRS_KISS_PORT=8001

# Where parsed positions are sent
APRS_MAPPING_SERVER_URL=http://host.docker.internal:18082

# Optional auth for the mapping server
APRS_AUTH_TOKEN=

# Logging: debug, info, warn, error
APRS_LOG_LEVEL=info
