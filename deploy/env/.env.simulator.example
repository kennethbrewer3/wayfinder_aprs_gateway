# Simulator input for development and testing.
# Copy to your compose directory as .env:
#   cp deploy/env/.env.simulator.example .env
#
# Also copy the simulator scenario file:
#   cp deploy/simulator.example.json simulator.json

APRS_PACKET_SOURCE=simulator
APRS_SIMULATOR_CONFIG=/app/simulator.json
APRS_SIMULATOR_LAYER_NAME=APRS Simulator

# Where parsed positions are sent
APRS_MAPPING_SERVER_URL=http://host.docker.internal:18080/api/aprs/position

# Optional auth for the mapping server
APRS_AUTH_TOKEN=

# More verbose logging helps while developing the simulator
APRS_LOG_LEVEL=debug
