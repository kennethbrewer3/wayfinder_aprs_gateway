# KISS input with network_mode: host in docker-compose.yml.
# Copy to your compose directory as .env:
#   cp deploy/env/.env.kiss.host-network.example .env
#
# Remove extra_hosts when using host networking.

APRS_PACKET_SOURCE=kiss

APRS_KISS_HOST=127.0.0.1
APRS_KISS_PORT=8001

APRS_MAPPING_SERVER_URL=http://127.0.0.1:18080/api/aprs/position

APRS_AUTH_TOKEN=

APRS_LOG_LEVEL=info
